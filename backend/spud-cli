#!/usr/bin/env python3
"""
spud-cli — interactive shell interface for spud-router.
This file is the executable entrypoint installed at /usr/local/bin/spud-cli.
All logic lives in the cli/ package.
"""
import sys
import os

# Add the backend directory to the path so `cli` is importable
sys.path.insert(0, "/opt/spud-router/backend")

from cli.main import main

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\nInterrupted. Goodbye.\n")
        sys.exit(0)
